SECRET_KEY=changez-moi-en-dev
DATABASE_URL=

# Mistral AI — note curatoriale auto (récupérer depuis Scalingo: scalingo --app artworksdigital env-get MISTRAL_API_KEY)
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
MISTRAL_MODEL_HEAVY=mistral-large-latest
AI_PRIMARY=mistral

# --- Stripe (récupérer depuis Scalingo: scalingo --app artworksdigital env) ---
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
SITE_URL=http://127.0.0.1:8080
# STRIPE_DEMO_MODE=1

# Google Places — autocomplete villes (dashboard profil)
GOOGLE_PLACES_API_KEY=

# Google OAuth — connexion / inscription (Google Cloud Console)
# URI de redirection autorisée : {SITE_URL}/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- CRM / Email SMTP (Scalingo: SMTP_HOST, SMTP_USER, SMTP_PASSWORD) ---
# sync: python sync_smtp_env.py
SMTP_HOST=mail.artworksdigital.fr
SMTP_PORT=465
SMTP_USER=contact@artworksdigital.fr
SMTP_PASSWORD=
SMTP_FROM=contact@artworksdigital.fr
SMTP_FROM_NAME=Artworks
MAIL_USE_TLS=0

